# REQUIRED
TELEGRAM_BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE

# SECURITY: recommended. Put your Telegram numeric user id.
# Example: ALLOWED_USER_IDS=123456789
# Multiple users: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=

# Railway/health server
PORT=3000

# Browser mode
HEADLESS=true
DEFAULT_START_URL=https://www.google.com
VIEWPORT_WIDTH=1365
VIEWPORT_HEIGHT=768
DEVICE_SCALE_FACTOR=1

# Browser behavior
MAX_TARGETS=30
SHOW_BOXES_AFTER_EACH_ACTION=true
NAVIGATION_TIMEOUT_MS=60000
ACTION_DELAY_MS=400
SLOW_MO=0

# Optional localization
TIMEZONE_ID=Asia/Baghdad
LOCALE=ar-IQ

# Optional custom browser executable.
# For Chromax on Railway you need a Linux executable path, not Windows .exe.
# Example: BROWSER_EXECUTABLE_PATH=/app/chromax/chromax
BROWSER_EXECUTABLE_PATH=

# Extra Chromium/Chromax args separated by spaces
# Example: BROWSER_ARGS=--fingerprint-platform=Win32 --fingerprint-screen-resolution=1920x1080
BROWSER_ARGS=

# Optional proxy
# Examples:
# PROXY_SERVER=http://host:port
# PROXY_SERVER=socks5://host:port
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
