# مطلوب
TELEGRAM_BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE

# مهم جدا: اكتب آيدي حسابك في تيليجرام حتى لا يستخدم البوت غيرك.
# مثال: ALLOWED_USER_IDS=123456789
# إذا لديك أكثر من مستخدم: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=PUT_YOUR_TELEGRAM_USER_ID_HERE

# Railway
PORT=3000

# المتصفح
HEADLESS=true
DEFAULT_START_URL=https://www.google.com
VIEWPORT_WIDTH=1365
VIEWPORT_HEIGHT=768
DEVICE_SCALE_FACTOR=1
MAX_TARGETS=30
SHOW_BOXES_AFTER_EACH_ACTION=true
NAVIGATION_TIMEOUT_MS=60000
ACTION_DELAY_MS=400
SLOW_MO=0
TIMEZONE_ID=Asia/Baghdad
LOCALE=ar-IQ

# اتركه فارغا لاستخدام Chromium الموجود داخل Docker image.
# إذا عندك Chromax Linux داخل المشروع، ضع المسار هنا مثل: /app/chromax/chromax
BROWSER_EXECUTABLE_PATH=
BROWSER_ARGS=

# بروكسي اختياري
# أمثلة:
# PROXY_SERVER=http://host:port
# PROXY_SERVER=socks5://host:port
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
